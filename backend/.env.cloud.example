# Copy to backend/.env and fill in your Upstash REDIS_URL (free at https://upstash.com)
NODE_ENV=development
PORT=3000

# Option 1: local PostgreSQL 17 (after running scripts/init-postgres.sql)
DATABASE_URL=postgresql://gateway:gateway@localhost:5432/integration_gateway

# Option 2: Neon cloud Postgres (free at https://neon.tech)
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/integration_gateway?sslmode=require

# Required: Upstash Redis (free, no install) — https://console.upstash.com
REDIS_URL=rediss://default:YOUR_UPSTASH_TOKEN@YOUR-ENDPOINT.upstash.io:6379

ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
WEBHOOK_SIGNING_SECRET=dev-webhook-signing-secret-change-me
DOWNLOAD_SIGNING_SECRET=dev-download-signing-secret-change-me
PUBLIC_API_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:5173
SEED_DEMO_PARTNER=true
DEMO_API_KEY=igw_demo_local_dev_key_12345
